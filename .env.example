# Local-only example. Do not put real values in git.
#
# For live phases later, each account should use a separate env prefix.
# The config stores the prefix only, not the secret values.

MOCK_EXCHANGE_PAPER_1_API_KEY=
MOCK_EXCHANGE_PAPER_1_API_SECRET=
MOCK_EXCHANGE_PAPER_1_PRIVATE_KEY=

MOCK_EXCHANGE_PAPER_2_API_KEY=
MOCK_EXCHANGE_PAPER_2_API_SECRET=
MOCK_EXCHANGE_PAPER_2_PRIVATE_KEY=

# Hibachi local-only credentials.
# Keep real values only in .env, never in config or chat.
# Prefix matching is case-insensitive.
#
# Hibachi has separated Crypto and FX wallets/API keys inside one logical account.
# Leave an entire wallet block blank when that wallet should not be used.
HIBACHI_API_KEY_PRODUCTION=
HIBACHI_PUBLIC_KEY_PRODUCTION=
HIBACHI_PRIVATE_KEY_PRODUCTION=
HIBACHI_ACCOUNT_ID_PRODUCTION=

# Hibachi 1 Crypto wallet credentials.
HIBACHI_1_CRYPTO_API_KEY_PRODUCTION=
HIBACHI_1_CRYPTO_PUBLIC_KEY_PRODUCTION=
HIBACHI_1_CRYPTO_PRIVATE_KEY_PRODUCTION=
HIBACHI_1_CRYPTO_ACCOUNT_ID_PRODUCTION=

# Legacy alias for Hibachi 1 Crypto.
# Existing local .env files may still use this block. New setup should prefer HIBACHI_1_CRYPTO_*.
HIBACHI_1_API_KEY_PRODUCTION=
HIBACHI_1_PUBLIC_KEY_PRODUCTION=
HIBACHI_1_PRIVATE_KEY_PRODUCTION=
HIBACHI_1_ACCOUNT_ID_PRODUCTION=

# Hibachi 1 FX wallet credentials.
HIBACHI_1_FX_API_KEY_PRODUCTION=
HIBACHI_1_FX_PUBLIC_KEY_PRODUCTION=
HIBACHI_1_FX_PRIVATE_KEY_PRODUCTION=
HIBACHI_1_FX_ACCOUNT_ID_PRODUCTION=

# Hibachi 2 Crypto wallet credentials.
HIBACHI_2_CRYPTO_API_KEY_PRODUCTION=
HIBACHI_2_CRYPTO_PUBLIC_KEY_PRODUCTION=
HIBACHI_2_CRYPTO_PRIVATE_KEY_PRODUCTION=
HIBACHI_2_CRYPTO_ACCOUNT_ID_PRODUCTION=

# Legacy alias for Hibachi 2 Crypto.
HIBACHI_2_API_KEY_PRODUCTION=
HIBACHI_2_PUBLIC_KEY_PRODUCTION=
HIBACHI_2_PRIVATE_KEY_PRODUCTION=
HIBACHI_2_ACCOUNT_ID_PRODUCTION=

# Hibachi 2 FX wallet credentials.
HIBACHI_2_FX_API_KEY_PRODUCTION=
HIBACHI_2_FX_PUBLIC_KEY_PRODUCTION=
HIBACHI_2_FX_PRIVATE_KEY_PRODUCTION=
HIBACHI_2_FX_ACCOUNT_ID_PRODUCTION=

HIBACHI_LIVE_CREDENTIAL_PREFIX=HIBACHI_1_CRYPTO
HIBACHI_API_ENDPOINT_PRODUCTION=https://api.hibachi.xyz
HIBACHI_DATA_API_ENDPOINT_PRODUCTION=https://data-api.hibachi.xyz

# Optional comma-separated public GET paths, after official docs confirm them.
# Leave blank until the exact read-only endpoint paths are verified.
HIBACHI_PUBLIC_READONLY_PATHS_PRODUCTION=/market/exchange-info

# Hotstuff local-only settings.
# Keep real private keys only in local .env or OS environment variables.
HOTSTUFF_API_ENDPOINT_PRODUCTION=https://api.hotstuff.trade
HOTSTUFF_API_ENDPOINT_TESTNET=https://testnet-api.hotstuff.trade
HOTSTUFF_WSS_ENDPOINT_PRODUCTION=wss://api.hotstuff.trade/ws
HOTSTUFF_WSS_ENDPOINT_TESTNET=wss://testnet-api.hotstuff.trade/ws

# Owner/account wallet used for private read-only account data.
HOTSTUFF_ACCOUNT_ADDRESS_PRODUCTION=
HOTSTUFF_ACCOUNT_ADDRESS_TESTNET=

# Hotstuff API Wallet / agent signer used for programmatic trading.
HOTSTUFF_SIGNER_ADDRESS_PRODUCTION=
HOTSTUFF_SIGNER_PRIVATE_KEY_PRODUCTION=
HOTSTUFF_SIGNER_ADDRESS_TESTNET=
HOTSTUFF_SIGNER_PRIVATE_KEY_TESTNET=

# Legacy fallback. New setup should prefer HOTSTUFF_SIGNER_PRIVATE_KEY_*.
HOTSTUFF_PRIVATE_KEY_PRODUCTION=
HOTSTUFF_PRIVATE_KEY_TESTNET=

# RiseX local-only settings.
# Public REST endpoints are not secrets.
RISEX_API_ENDPOINT_TESTNET=https://api.testnet.rise.trade
RISEX_WSS_ENDPOINT_TESTNET=wss://ws.testnet.rise.trade
RISEX_API_ENDPOINT_PRODUCTION=https://api.rise.trade
RISEX_WSS_ENDPOINT_PRODUCTION=wss://ws.risex.trade

# Owner/account wallet used for private read-only account data.
RISEX_ACCOUNT_ADDRESS_TESTNET=
RISEX_ACCOUNT_ADDRESS_PRODUCTION=

# RiseX session signer used later for authenticated order signing.
# Put real private keys only in local .env or OS env, never in this example file.
# Current RiseX tools check key format/address match and preflight only; they do not submit orders.
RISEX_SIGNER_ADDRESS_TESTNET=
RISEX_SIGNER_PRIVATE_KEY_TESTNET=
RISEX_SIGNER_ADDRESS_PRODUCTION=
RISEX_SIGNER_PRIVATE_KEY_PRODUCTION=

# Pacifica local-only settings.
# Official docs confirm REST and WebSocket endpoints for production and testnet.
PACIFICA_API_ENDPOINT_TESTNET=https://test-api.pacifica.fi/api/v1
PACIFICA_WSS_ENDPOINT_TESTNET=wss://test-ws.pacifica.fi/ws
PACIFICA_API_ENDPOINT_PRODUCTION=https://api.pacifica.fi/api/v1
PACIFICA_WSS_ENDPOINT_PRODUCTION=wss://ws.pacifica.fi/ws

# Owner/account wallet used for private read-only account data.
PACIFICA_ACCOUNT_ADDRESS_TESTNET=
PACIFICA_ACCOUNT_ADDRESS_PRODUCTION=

# Pacifica API Agent key used later for authenticated order signing.
# UI label "API Key" means the API Agent public key.
# Keep real API Agent private keys only in local .env or OS environment variables.
# Live submission still requires an explicit CLI confirmation string.
PACIFICA_API_AGENT_PUBLIC_KEY_TESTNET=
PACIFICA_API_AGENT_PRIVATE_KEY_TESTNET=
PACIFICA_API_AGENT_PUBLIC_KEY_PRODUCTION=
PACIFICA_API_AGENT_PRIVATE_KEY_PRODUCTION=

# Hyperliquid local-only settings.
# Official API docs use these mainnet/testnet REST endpoints.
HYPERLIQUID_API_ENDPOINT_TESTNET=https://api.hyperliquid-testnet.xyz
HYPERLIQUID_API_ENDPOINT_PRODUCTION=https://api.hyperliquid.xyz

# Master/subaccount address used for private read-only account data.
# Do not put the API wallet address here.
HYPERLIQUID_ACCOUNT_ADDRESS_TESTNET=
HYPERLIQUID_ACCOUNT_ADDRESS_PRODUCTION=

# API wallet / agent wallet used later for signing only.
# Keep real private keys only in local .env or OS environment variables.
# Live submission requires a separate guarded CLI confirmation string.
HYPERLIQUID_API_WALLET_ADDRESS_TESTNET=
HYPERLIQUID_API_WALLET_PRIVATE_KEY_TESTNET=
HYPERLIQUID_API_WALLET_ADDRESS_PRODUCTION=
HYPERLIQUID_API_WALLET_PRIVATE_KEY_PRODUCTION=

# Optional vault/subaccount execution address. Leave blank unless reviewed against official docs.
HYPERLIQUID_VAULT_ADDRESS_TESTNET=
HYPERLIQUID_VAULT_ADDRESS_PRODUCTION=

# Lighter local-only settings.
# Official docs confirm the production REST endpoint and both WebSocket endpoints.
# Testnet REST is intentionally blank until confirmed from official docs or SDK output.
LIGHTER_API_ENDPOINT_PRODUCTION=https://mainnet.zklighter.elliot.ai
LIGHTER_WSS_ENDPOINT_PRODUCTION=wss://mainnet.zklighter.elliot.ai/stream
LIGHTER_API_ENDPOINT_TESTNET=
LIGHTER_WSS_ENDPOINT_TESTNET=wss://testnet.zklighter.elliot.ai/stream

# L1 wallet and Lighter account index used for private read-only account data.
LIGHTER_L1_ADDRESS_PRODUCTION=
LIGHTER_ACCOUNT_INDEX_PRODUCTION=
LIGHTER_L1_ADDRESS_TESTNET=
LIGHTER_ACCOUNT_INDEX_TESTNET=

# Lighter API key used later for SDK auth/signing.
# Keep real private keys only in local .env or OS environment variables.
# Phase 0 tools do not submit orders, cancels, transfers, or withdrawals.
LIGHTER_API_KEY_INDEX_PRODUCTION=
LIGHTER_API_PRIVATE_KEY_PRODUCTION=
LIGHTER_API_KEY_INDEX_TESTNET=
LIGHTER_API_PRIVATE_KEY_TESTNET=

# Optional read-only auth token for auth-gated account/order endpoints.
LIGHTER_READ_ONLY_AUTH_TOKEN_PRODUCTION=
LIGHTER_READ_ONLY_AUTH_TOKEN_TESTNET=

# Optional local paths for paper-only bot data. These are not secrets.
PERPDEX_FARMING_BOT_DB=data/hibachi_paper.sqlite
PERPDEX_DATA_HUB_DB=
PERPDEX_DATA_HUB_MARKETS_CONFIG=
PERPDEX_RUNTIME_CONTROL_FILE=data/runtime_control.json

# Optional Telegram monitor/control bot.
# Keep real values only in local .env.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
